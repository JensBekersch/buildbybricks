{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buildbybricks.local/schemas/software-factory/architecture-sheet.schema.json",
  "title": "Software Factory Architecture Sheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_name",
    "artifact_type",
    "input_summary",
    "business_goal",
    "stakeholders",
    "architecture_drivers",
    "quality_goals",
    "constraints",
    "context",
    "solution_strategy",
    "architecture_decisions",
    "building_blocks",
    "runtime_scenarios",
    "deployment_view",
    "data_view",
    "security_view",
    "test_strategy",
    "acceptance_criteria",
    "risks",
    "open_questions",
    "assumptions",
    "readiness",
    "arc42"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version des Architecture-Sheet-Contracts."
    },
    "artifact_name": {
      "type": "string",
      "minLength": 1,
      "description": "Kurzer, sprechender Name des geplanten Softwareartefakts."
    },
    "artifact_type": {
      "type": "string",
      "description": "Typ des geplanten Django-Softwareartefakts.",
      "enum": [
        "django-application",
        "django-service",
        "django-app-module",
        "unknown"
      ]
    },
    "input_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Verdichtete Zusammenfassung der Nutzerbeschreibung als Grundlage fuer das Sheet."
    },
    "business_goal": {
      "type": "string",
      "minLength": 1,
      "description": "Fachliches Ziel und erwarteter Nutzen des Artefakts."
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/named_item"
      }
    },
    "architecture_drivers": {
      "type": "array",
      "minItems": 1,
      "description": "Wichtigste Treiber, die Architekturentscheidungen beeinflussen.",
      "items": {
        "$ref": "#/$defs/architecture_driver"
      }
    },
    "quality_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/quality_goal"
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "users",
        "external_systems",
        "interfaces"
      ],
      "properties": {
        "users": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "external_systems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface_item"
          }
        }
      }
    },
    "solution_strategy": {
      "type": "string",
      "minLength": 1,
      "description": "Kurze technische Strategie fuer den ersten Architekturentwurf."
    },
    "architecture_decisions": {
      "type": "array",
      "minItems": 1,
      "description": "Explizite Architekturentscheidungen mit Begruendung und Status.",
      "items": {
        "$ref": "#/$defs/architecture_decision"
      }
    },
    "building_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/building_block"
      }
    },
    "runtime_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/runtime_scenario"
      }
    },
    "deployment_view": {
      "type": "string",
      "minLength": 1
    },
    "data_view": {
      "type": "string",
      "minLength": 1
    },
    "security_view": {
      "type": "string",
      "minLength": 1
    },
    "test_strategy": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "description": "Pruefbare Kriterien, ab wann das Architecture Sheet fuer Folgeagenten brauchbar ist.",
      "items": {
        "$ref": "#/$defs/acceptance_criterion"
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "needs-clarification",
            "ready-for-review",
            "approved"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "arc42": {
      "$ref": "#/$defs/arc42_document"
    }
  },
  "$defs": {
    "arc42_document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "introduction_and_goals",
        "constraints",
        "context_and_scope",
        "solution_strategy",
        "building_block_view",
        "runtime_view",
        "deployment_view",
        "crosscutting_concepts",
        "architecture_decisions",
        "quality_requirements",
        "risks_and_technical_debt",
        "glossary"
      ],
      "properties": {
        "introduction_and_goals": {
          "$ref": "#/$defs/arc42_introduction_and_goals"
        },
        "constraints": {
          "$ref": "#/$defs/arc42_constraints"
        },
        "context_and_scope": {
          "$ref": "#/$defs/arc42_context_and_scope"
        },
        "solution_strategy": {
          "$ref": "#/$defs/arc42_solution_strategy"
        },
        "building_block_view": {
          "$ref": "#/$defs/arc42_building_block_view"
        },
        "runtime_view": {
          "$ref": "#/$defs/arc42_runtime_view"
        },
        "deployment_view": {
          "$ref": "#/$defs/arc42_deployment_view"
        },
        "crosscutting_concepts": {
          "$ref": "#/$defs/arc42_crosscutting_concepts"
        },
        "architecture_decisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architecture_decision"
          }
        },
        "quality_requirements": {
          "$ref": "#/$defs/arc42_quality_requirements"
        },
        "risks_and_technical_debt": {
          "$ref": "#/$defs/arc42_risks_and_technical_debt"
        },
        "glossary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/glossary_item"
          }
        }
      }
    },
    "arc42_introduction_and_goals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "goals",
        "stakeholders",
        "quality_goals",
        "non_goals"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "stakeholders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "quality_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/quality_goal"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "arc42_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraints",
        "assumptions",
        "open_questions"
      ],
      "properties": {
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "arc42_context_and_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_context",
        "technical_context",
        "in_scope",
        "out_of_scope",
        "not_evidenced"
      ],
      "properties": {
        "business_context": {
          "$ref": "#/$defs/context"
        },
        "technical_context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface_item"
          }
        },
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "not_evidenced": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "arc42_solution_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "key_ideas"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "key_ideas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "arc42_building_block_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "building_blocks"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "building_blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/building_block"
          }
        }
      }
    },
    "arc42_runtime_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "scenarios"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/runtime_scenario"
          }
        }
      }
    },
    "arc42_deployment_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "nodes",
        "assumptions"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "arc42_crosscutting_concepts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concepts"
      ],
      "properties": {
        "concepts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/named_item"
          }
        }
      }
    },
    "arc42_quality_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_goals",
        "quality_scenarios"
      ],
      "properties": {
        "quality_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/quality_goal"
          }
        },
        "quality_scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acceptance_criterion"
          }
        }
      }
    },
    "arc42_risks_and_technical_debt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risks",
        "technical_debt"
      ],
      "properties": {
        "risks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/risk"
          }
        },
        "technical_debt": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        }
      }
    },
    "architecture_driver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "impact"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "architecture_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "decision",
        "rationale",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "rejected",
            "superseded"
          ]
        }
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "verification"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "named_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "text_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "quality_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scenario",
        "priority"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "interface_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "web-ui",
            "rest-api",
            "admin-ui",
            "background-job",
            "database",
            "external-api",
            "file-export",
            "unknown"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "users",
        "external_systems",
        "interfaces"
      ],
      "properties": {
        "users": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "external_systems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface_item"
          }
        }
      }
    },
    "glossary_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "definition"
      ],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        }
      }
    },
    "building_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "responsibility",
        "django_mapping"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "responsibility": {
          "type": "string",
          "minLength": 1
        },
        "django_mapping": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "steps"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "mitigation"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mitigation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
