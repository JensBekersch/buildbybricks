{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buildbybricks.local/schemas/software-factory/architecture-sheet.schema.json",
  "title": "Software Factory Architecture Sheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_name",
    "artifact_type",
    "input_summary",
    "business_goal",
    "stakeholders",
    "architecture_drivers",
    "quality_goals",
    "constraints",
    "context",
    "solution_strategy",
    "architecture_decisions",
    "building_blocks",
    "runtime_scenarios",
    "deployment_view",
    "data_view",
    "security_view",
    "test_strategy",
    "acceptance_criteria",
    "risks",
    "open_questions",
    "assumptions",
    "readiness"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version des Architecture-Sheet-Contracts."
    },
    "artifact_name": {
      "type": "string",
      "minLength": 1,
      "description": "Kurzer, sprechender Name des geplanten Softwareartefakts."
    },
    "artifact_type": {
      "type": "string",
      "description": "Typ des geplanten Django-Softwareartefakts.",
      "enum": [
        "django-application",
        "django-service",
        "django-app-module",
        "unknown"
      ]
    },
    "input_summary": {
      "type": "string",
      "minLength": 1,
      "description": "Verdichtete Zusammenfassung der Nutzerbeschreibung als Grundlage fuer das Sheet."
    },
    "business_goal": {
      "type": "string",
      "minLength": 1,
      "description": "Fachliches Ziel und erwarteter Nutzen des Artefakts."
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/named_item"
      }
    },
    "architecture_drivers": {
      "type": "array",
      "minItems": 1,
      "description": "Wichtigste Treiber, die Architekturentscheidungen beeinflussen.",
      "items": {
        "$ref": "#/$defs/architecture_driver"
      }
    },
    "quality_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/quality_goal"
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "users",
        "external_systems",
        "interfaces"
      ],
      "properties": {
        "users": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "external_systems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/named_item"
          }
        },
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface_item"
          }
        }
      }
    },
    "solution_strategy": {
      "type": "string",
      "minLength": 1,
      "description": "Kurze technische Strategie fuer den ersten Architekturentwurf."
    },
    "architecture_decisions": {
      "type": "array",
      "minItems": 1,
      "description": "Explizite Architekturentscheidungen mit Begruendung und Status.",
      "items": {
        "$ref": "#/$defs/architecture_decision"
      }
    },
    "building_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/building_block"
      }
    },
    "runtime_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/runtime_scenario"
      }
    },
    "deployment_view": {
      "type": "string",
      "minLength": 1
    },
    "data_view": {
      "type": "string",
      "minLength": 1
    },
    "security_view": {
      "type": "string",
      "minLength": 1
    },
    "test_strategy": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/text_item"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "description": "Pruefbare Kriterien, ab wann das Architecture Sheet fuer Folgeagenten brauchbar ist.",
      "items": {
        "$ref": "#/$defs/acceptance_criterion"
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "needs-clarification",
            "ready-for-review",
            "approved"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "architecture_driver": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "impact"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "architecture_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "decision",
        "rationale",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "rejected",
            "superseded"
          ]
        }
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "verification"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "named_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "text_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "quality_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "scenario",
        "priority"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "interface_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "web-ui",
            "rest-api",
            "admin-ui",
            "background-job",
            "database",
            "external-api",
            "file-export",
            "unknown"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "building_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "responsibility",
        "django_mapping"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "responsibility": {
          "type": "string",
          "minLength": 1
        },
        "django_mapping": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "steps"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "mitigation"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mitigation": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
