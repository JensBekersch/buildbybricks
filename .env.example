# Runtime paths
AGENTIC_RAG_DATA_DIR=data
AGENTIC_RAG_TEMPLATE_DIR=template
AGENTIC_RAG_APPS_DIR=apps
AGENTIC_RAG_FRONTEND_DIR=frontend

# Persistent job storage.
AGENTIC_RAG_DATABASE_URL=postgresql://agentic_rag:agentic_rag@postgres:5432/agentic_rag
AGENTIC_RAG_WORKER_POLL_SECONDS=2
AGENTIC_RAG_JOB_STREAM_POLL_SECONDS=1
POSTGRES_DB=agentic_rag
POSTGRES_USER=agentic_rag
POSTGRES_PASSWORD=agentic_rag

# Current default: deterministic local test embeddings, no external service.
# Local Ollama embedding example:
# AGENTIC_RAG_EMBEDDING_PROVIDER=ollama
# AGENTIC_RAG_EMBEDDING_MODEL=nomic-embed-text
# AGENTIC_RAG_EMBEDDING_DIMENSION=0
AGENTIC_RAG_EMBEDDING_PROVIDER=hash
AGENTIC_RAG_EMBEDDING_MODEL=local-hash-v1
AGENTIC_RAG_EMBEDDING_DIMENSION=64
AGENTIC_RAG_EMBEDDING_API_BASE_URL=http://ollama:11434
AGENTIC_RAG_EMBEDDING_API_KEY=

# Current default: deterministic answer composer, no external LLM.
# Local Ollama example:
# AGENTIC_RAG_LLM_PROVIDER=ollama
# AGENTIC_RAG_LLM_MODEL=llama3.1
# AGENTIC_RAG_LLM_API_BASE_URL=http://ollama:11434
AGENTIC_RAG_LLM_PROVIDER=deterministic
AGENTIC_RAG_LLM_MODEL=local-deterministic-v1
AGENTIC_RAG_LLM_API_BASE_URL=http://ollama:11434
AGENTIC_RAG_LLM_API_KEY=
AGENTIC_RAG_LLM_TIMEOUT_SECONDS=1200
AGENTIC_RAG_LLM_MAX_TOKENS=4096
AGENTIC_RAG_ARCHITECTURE_GENERATION_MODE=agentic_with_review

# Ollama runtime tuning for local/server CPU usage.
OLLAMA_NUM_THREADS=12
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Software Factory architecture sheets require a structured LLM provider.
# Local agentic Architecture Sheet runs can take several minutes with Ollama.
# Use generation_mode agentic or agentic_with_review in the API/UI.
